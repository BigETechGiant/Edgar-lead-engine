# ---------------------------------------------------------------------------
# edgar-lead-engine environment variables
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# PORT is NOT listed here on purpose — Railway injects it at runtime.
# ---------------------------------------------------------------------------

# --- Supabase (self-hosted) ---
# PostgREST API host = the dashboard's NEXT_PUBLIC_SUPABASE_URL.
# NOTE: this is NOT the Studio admin host (supabase.besolhub.com), which is
# correctly locked behind nginx Basic Auth and does not serve the REST API.
SUPABASE_URL=
# Service role key (server-side only, full access — keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude enrichment layer) ---
ANTHROPIC_API_KEY=

# --- SEC EDGAR ---
# SEC REQUIRES a descriptive User-Agent on every request, e.g.
# "Solventis Lead Engine ops@solventis.example.com"
EDGAR_USER_AGENT=

# --- HTTP trigger auth ---
# Shared secret the Solventis dashboard sends in the x-api-key header on POST /trigger
EDGAR_ENGINE_KEY=

# --- Scoring / lookback tuning ---
# Minimum lead score to persist (default 40). Leads >= 65 are flagged high priority.
MIN_LEAD_SCORE=40
# How many days back each monitor scans (default 7).
LOOKBACK_DAYS=7
# Minimum lead score to send to Claude for enrichment (default 65). Separate
# from MIN_LEAD_SCORE — bounds Anthropic spend to the highest-value leads.
ENRICHMENT_MIN_SCORE=65

# --- Postal (outbound email via Postal HTTP API) ---
# Postal server message-send endpoint, e.g. https://postal.example.com/api/v1/send/message
POSTAL_ENDPOINT=
# Postal API credential (sent as X-Server-API-Key header)
POSTAL_API_KEY=

# --- Daily digest recipients ---
# Comma-separated lists are supported for DIGEST_TO and DIGEST_CC.
DIGEST_TO=
DIGEST_CC=
DIGEST_FROM=
